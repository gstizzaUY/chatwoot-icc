# ===================================
# Variables de entorno - API v2
# ===================================

# Configuración del servidor
PORT=4000
NODE_ENV=development

# ===================================
# CHATWOOT
# ===================================
CHATWOOT_URL=https://contact-center.5vsa59.easypanel.host
CHATWOOT_ACCOUNT_ID=2
API_ACCESS_TOKEN=your_chatwoot_api_token_here

# Tokens de webhook de Chatwoot (DEPRECADOS - ya no se usan)
# Los webhooks ahora están protegidos por rate limiting en lugar de tokens
# Para mayor seguridad, usar IP whitelist a nivel de infraestructura
# CHATWOOT_WEBHOOK_TOKEN=your_conversation_webhook_token_here
# CHATWOOT_MESSAGE_WEBHOOK_TOKEN=your_message_webhook_token_here

# ===================================
# RD STATION
# ===================================
RDSTATION_URL=https://api.rd.services
RDSTATION_CRM_URL=https://crm.rdstation.com

# OAuth2 Credentials
RDSTATION_CLIENT_ID=your_rd_client_id_here
RDSTATION_CLIENT_SECRET=your_rd_client_secret_here
RDSTATION_REFRESH_TOKEN=your_rd_refresh_token_here

# CRM User Token (para deals)
RDSTATION_USER_TOKEN=your_rd_user_token_here

# Campos personalizados disponibles en RD Station
# Estos campos deben crearse en RD Station antes de usarlos
# Formato: lista separada por comas (sin espacios)
# IMPORTANTE: Solo incluir campos que existan en tu cuenta de RD Station
RDSTATION_CUSTOM_FIELDS=cf_tiene_ichef

# Campos básicos disponibles:
# cf_tiene_ichef, cf_es_cliente, cf_id_equipo, cf_chatwoot_id, cf_last_sync_from_chatwoot
# cf_address1, cf_address2, cf_cedula, cf_comments, cf_client_comments, cf_categoria_contacto
# cf_cupon_url, cf_demo_fecha_hora, cf_enc_acesso_ichef

# Campos de encuesta disponibles:
# enc_experiencia, enc_gusta_cocinar, enc_frecuencia_cocina, enc_cantidad_personas_Cocina
# enc_condicion_alimenticia, enc_gustos_alimenticios, enc_mayor_desafio, enc_nucleo_familiar
# enc_profesional, enc_quien_cocina_casa, enc_via_se_entero_ichef, enc_contenido_preferido
# enc_sugerencia_contenido, enc_onb_ayudarte, enc_onb_experiencia_30_dias, enc_onb_experiencia_ichef
# enc_onb_mas_te_gusto, enc_onb_mejorar, enc_onb_recetas_encantaron, enc_onb_tres_recetas
# enc_onb_filtros, enc_onb_categorias_alimentos_portal

# Otros campos:
# numero_puerta, zip, rut, referido_por, referente, referidos, fuente_contacto
# envia_cupon_despues, estado_sdr, forma_pago, uso, version_firmware, status_contacto, stage

# Ejemplo con múltiples campos:
# RDSTATION_CUSTOM_FIELDS=cf_tiene_ichef,cf_es_cliente,cf_id_equipo,enc_experiencia,enc_gusta_cocinar

# Nota: Si un campo no existe en RD Station, RD retornará error 400
# Para crear campos personalizados en RD Station:
# 1. Ir a Configurações > Campos personalizados
# 2. Crear campo con el nombre exacto (ej: cf_tiene_ichef)
# 3. Agregar el nombre a RDSTATION_CUSTOM_FIELDS

# Token de webhook de RD Station (DEPRECADO - ya no se usa)
# RD Station no permite enviar headers personalizados en webhooks
# Protección: Rate limiting + validación de payload
# RDSTATION_WEBHOOK_TOKEN=your_rd_webhook_token_here

# ===================================
# OPENAI (Análisis de Conversaciones con IA)
# ===================================
# API Key de OpenAI para análisis inteligente de conversaciones
# Si no se configura, el sistema usará análisis básico por regex
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Modelo a usar (opcional, por defecto: gpt-4o-mini)
# Opciones: gpt-4o-mini (económico), gpt-4o (mejor calidad)
# Costo aproximado: $0.005-0.01 por conversación con gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ===================================
# EVOLUTION API (WhatsApp)
# ===================================
EVOLUTION_API_URL=your_evolution_api_url_here
EVOLUTION_API_TOKEN=your_evolution_api_token_here

# ===================================
# NOTEBOOKLM MCP
# ===================================
# URL del servidor MCP de NotebookLM
NOTEBOOKLM_MCP_URL=http://127.0.0.1:3000/mcp

# URLs de los notebooks de Google NotebookLM por equipo
# Obtener de la URL del navegador al abrir cada notebook
NOTEBOOKLM_URL_COMERCIAL=https://notebooklm.google.com/notebook/...
NOTEBOOKLM_URL_PREVENTA=https://notebooklm.google.com/notebook/...
NOTEBOOKLM_URL_POSTVENTA=https://notebooklm.google.com/notebook/...
NOTEBOOKLM_URL_PORTAL=https://notebooklm.google.com/notebook/...

# ===================================
# AUTENTICACIÓN API
# ===================================
# API Key para endpoints de recursos (opcional)
API_KEY=your_internal_api_key_here

# Token para endpoints de exportación y reportes
EXPORT_SECRET=your_export_secret_here

# ===================================
# RATE LIMITING
# ===================================
# Desactivar rate limiting en desarrollo (true/false)
SKIP_RATE_LIMIT=false
